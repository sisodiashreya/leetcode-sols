class Solution {
    public boolean isHappy(int n) {
        int x=n;
        while(true){
            int s=0;
            while(x>0){
                s+=(x%10)*(x%10);
                x/=10;
            }
            if(s==1)
            return true;
            if(s==4)
            return false;
            x=s;

        }
       
    }
}
